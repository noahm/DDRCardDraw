STARTGG_TOKEN=YOUR_TOKEN_HERE

# Optional secondary backup of realtime room state, in addition to the
# local JSON files written by the realtime server under .room-state/
SUPABASE_URL=SOMETHING
SUPABASE_KEY=SOMETHING

# Host (and optional port) where the realtime server is reachable in
# production. Defaults to localhost:1999 in development.
REALTIME_HOST=YOUR_HOST_HERE
